{
  "name": "quillflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":        "next dev --turbo",
    "build":      "next build",
    "start":      "next start",
    "lint":       "next lint",
    "lint:fix":   "next lint --fix",
    "type-check": "tsc --noEmit",
    "db:types":   "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/lib/supabase/database.types.ts",
    "db:reset":   "supabase db reset",
    "prepare":    "husky"
  },
  "dependencies": {
    "next":                        "14.2.29",
    "react":                       "^18.3.1",
    "react-dom":                   "^18.3.1",
    "@supabase/supabase-js":       "^2.45.4",
    "@supabase/ssr":               "^0.5.2",
    "react-hook-form":             "^7.53.0",
    "@hookform/resolvers":         "^3.9.0",
    "zod":                         "^3.23.8",
    "recharts":                    "^2.13.0",
    "react-hot-toast":             "^2.4.1",
    "clsx":                        "^2.1.1",
    "tailwind-merge":              "^2.5.2"
  },
  "devDependencies": {
    "typescript":                  "^5.6.3",
    "@types/react":                "^18.3.11",
    "@types/react-dom":            "^18.3.1",
    "@types/node":                 "^22.7.5",
    "tailwindcss":                 "^3.4.14",
    "autoprefixer":                "^10.4.20",
    "postcss":                     "^8.4.47",
    "eslint":                      "^8.57.1",
    "eslint-config-next":          "14.2.29",
    "@netlify/plugin-nextjs":      "^5.7.0",
    "supabase":                    "^1.200.3",
    "husky":                       "^9.1.6",
    "lint-staged":                 "^15.2.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ]
  }
}
