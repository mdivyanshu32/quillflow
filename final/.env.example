# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.
# Add production values via Netlify > Site Settings > Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/_/settings/api

# Project URL — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key — safe to expose in the browser (RLS is your security layer)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY. Never expose to the browser.
# Used only in createAdminClient() for admin operations (webhooks, deleteAccount).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used in auth email redirect links (password reset, email confirm).
# Local dev:  http://localhost:3000
# Production: https://www.your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Webhook secret ────────────────────────────────────────────────────────────
# HMAC secret for verifying incoming webhooks. Generate with:
#   openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-hmac-secret-here
